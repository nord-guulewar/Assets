# ZTNA Gateway Dockerfile
FROM golang:1.21-alpine AS builder

WORKDIR /app

COPY ztna-server.go go.mod go.sum ./

RUN go mod init ztna-server && go mod tidy

RUN CGO_ENABLED=0 GOOS=linux go build -a -installsuffix cgo -o ztna-server .

FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /root/
COPY --from=builder /app/ztna-server .

EXPOSE 5003
CMD ["./ztna-server"]